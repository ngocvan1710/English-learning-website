					action: function () {
						ajaxCALL(vueData.v_Set.apiDomain + '/iotdev/TiengAnh_Delete', {
							TiengAnhID: record.TiengAnhID
						}, (res) => {
							console.log(res)
							$this.getData()
						})
					},
				})
			},
			getStarStyle(n) {
				const size = Math.random() * 3 + 1;
				const duration = Math.random() * 3 + 2;
				const delay = Math.random() * 3;
				const top = Math.random() * 100;
				const left = Math.random() * 100;
				return {
					width: size + 'px',
					height: size + 'px',
					top: top + '%',
					left: left + '%',
					animationDuration: duration + 's',
					animationDelay: delay + 's'
				};
			},
	
			// THÊM HÀM NÀY – CHUYỂN MÀU MÂY ĐỘNG
			getCloudStyle(index) {
				const hue = (index * 37) % 360
				return {
					background: `linear-gradient(135deg, hsla(${hue}, 70%, 20%, 0.3), hsla(${(hue + 60) % 360}, 70%, 15%, 0.2))`,
					animation: `cloudMove ${12 + index * 0.8}s linear infinite`,
					animationDelay: `${index * 0.5}s`,
					position: 'relative',
					overflow: 'hidden'
				}
			},
			getMeteorStyle(index) {
				const startX = Math.random() * 100; // từ 0% → 100%
				const endX = startX - 40 - Math.random() * 60; // bay chéo về trái
				const duration = 1.5 + Math.random() * 1.5; // 1.5s → 3s
				const delay = Math.random() * 8; // xuất hiện ngẫu nhiên
				const topStart = -10; // ngoài màn hình
				const size = 2 + Math.random() * 2; // độ dày vệt
	
				return {
					'--start-x': `${startX}%`,
					'--end-x': `${endX}%`,
					'--duration': `${duration}s`,
					'--delay': `${delay}s`,
					'--size': `${size}px`,
					top: `${topStart}%`,
					animation: `meteor ${duration}s linear ${delay}s infinite`
				};
			}
	
		}
