									variant="outlined" bg-color="#333">
								</v-textarea>
							</v-col>
						</v-row>
						<v-row>
							<v-col>
								<v-text-field label="Từ trái nghĩa" v-model="formVocab.TuTraiNghia" variant="outlined"
									bg-color="#333">
								</v-text-field>
							</v-col>
							<v-col>
								<v-textarea rows="3" label="Ví dụ từ trái nghĩa" v-model="formVocab.ViDuTuTraiNghia"
									variant="outlined" bg-color="#333">
								</v-textarea>
							</v-col>
						</v-row>
						<v-row>
							<v-col>
								<v-text-field label="Từ đồng nghĩa" v-model="formVocab.TuDongNghia" variant="outlined"
									bg-color="#333">
								</v-text-field>
							</v-col>
							<v-col>
								<v-textarea rows="3" label="Ví dụ từ đồng nghĩa" v-model="formVocab.ViDuTuDongNghia"
									variant="outlined" bg-color="#333">
								</v-textarea>
							</v-col>
						</v-row>
						<v-row>
							<v-col>
								<v-text-field label="Thành ngữ" v-model="formVocab.ThanhNguTA" variant="outlined"
									bg-color="#333">
								</v-text-field>
							</v-col>
						</v-row>
						<v-row>
							<v-col>
								<v-textarea rows="3" label="Nghĩa thành ngữ" v-model="formVocab.ThanhNguTV"
									variant="outlined" bg-color="#333">
								</v-textarea>
							</v-col>
							<v-col>
								<v-textarea rows="3" label="Ví dụ thành ngữ" v-model="formVocab.ViDuThanhNgu"
									variant="outlined" bg-color="#333">
								</v-textarea>
							</v-col>
						</v-row>
					</v-card-text>
					<v-card-actions>
						<v-spacer />
						<v-btn color="grey" text @click="dialogVocab = false">Hủy</v-btn>
						<v-btn color="#1da1f2" text @click="saveVocab" :disabled="!selectedTopic.ChuDeID">Lưu</v-btn>
					</v-card-actions>
				</v-card>
			</v-dialog>
		</div>
		<uc-quan-ly-dong-luc v-if="isShowMotivation" :topic="selectedTopic" @close="isShowMotivation = false" />
	</div>
</template>

<script>
	export default {
		data() {
			return {
				isShowMotivation: false,
				topics: [],
				selectedTopic: {},
				searchTopic: '',
				dialogTopic: false,
				formTopic: { ChuDeID: 0, TenChuDe: '', MoTaChuDe: '' },
	
				vocabList: [],
				searchVocab: '',
				dialogVocab: false,
				formVocab: { TiengAnhID: 0, TuVung: '', NghiaDenTA: '', NghiaDenTV: '', NghiaBong: '', NghiaBongTA: '', ViDuNghiaBong: '', ViDuNghiaDen: '', TuTraiNghia: '', ViDuTuTraiNghia: '', TuDongNghia: '', ViDuTuDongNghia: '', ThanhNguTA: '', ThanhNguTV: '', ViDuThanhNgu: '' },
	
				vocabHeaders: [
					{ text: 'STT', value: 'index', width: '60px', align: 'center' },
					{ text: 'Từ vựng', value: 'TuVung' },
					{ text: 'Nghĩa TA', value: 'NghiaDenTA' },
					{ text: 'Nghĩa TV', value: 'NghiaDenTV' },
					{ text: 'Nghĩa bóng', value: 'NghiaBong' },
					{ text: 'Nghĩa bóng TA', value: 'NghiaBongTA' },
					{ text: 'Ví dụ nghĩa bóng', value: 'ViDuNghiaBong' },
					{ text: 'Ví dụ nghĩa đen', value: 'ViDuNghiaDen' },
					{ text: 'Từ trái nghĩa', value: 'TuTraiNghia' },
					{ text: 'Ví dụ trái nghĩa', value: 'ViDuTuTraiNghia' },
					{ text: 'Từ đồng nghĩa', value: 'TuDongNghia' },
					{ text: 'Ví dụ đồng nghĩa', value: 'ViDuTuDongNghia' },
					{ text: 'Thành ngữ', value: 'ThanhNguTA' },
					{ text: 'Nghĩa thành ngữ', value: 'ThanhNguTV' },
					{ text: 'Ví dụ thành nghĩa', value: 'ViDuThanhNgu' },
					{ text: 'Thao tác', value: 'actions', align: 'center' }
				]
			}
		},
		computed: {
			sortedTopics() {
				return [...this.topics].sort((a, b) => {
					const nameA = (a.TenChuDe || '').trim().toLowerCase()
					const nameB = (b.TenChuDe || '').trim().toLowerCase()
					return nameA.localeCompare(nameB)
				})
			},
			sortedVocabList() {
				return [...this.vocabList].sort((a, b) => {
					const wordA = (a.TuVung || '').trim().toLowerCase()
					const wordB = (b.TuVung || '').trim().toLowerCase()
					return wordA.localeCompare(wordB)
				})
			},
			// Tìm kiếm 
			filteredTopics() {
				if (!this.searchTopic) return this.sortedTopics
				return this.sortedTopics.filter(t =>
					t.TenChuDe.toLowerCase().includes(this.searchTopic.toLowerCase())
				)
			}
		},
		mounted() {
			this.getTopics()
		},
		methods: {
			getTopics() {
				// Tạo 2 promise
				const topicsPromise = new Promise(resolve => {
					ajaxCALL(vueData.v_Set.apiDomain + '/iotdev/auth/ChuDeTiengAnh_Select', {
						SearchKeyword: this.searchTopic
					}, res => resolve(res.data || []))
				})
	
				const vocabPromise = new Promise(resolve => {
					ajaxCALL(vueData.v_Set.apiDomain + '/iotdev/auth/TiengAnh_Select', {
						ChuDeID: 0, SearchKeyword: ''
					}, res => resolve(res.data || []))
				})
	
				// Đợi cả 2 về
				Promise.all([topicsPromise, vocabPromise])
					.then(([topics, allVocab]) => {
						this.topics = topics.map(t => ({
							...t,
							SoTu: allVocab.filter(v => v.ChuDeID == t.ChuDeID).length
						}))
					})
					.catch(err => {
						console.error('Lỗi tải dữ liệu:', err)
						this.topics = []
					})
			},
			getRainbowStyle(index) {
				const hue = (index * 47 + Date.now() / 50) % 360 // Đổi màu từ từ
				return {
					'--hue': hue,
					background: `linear-gradient(135deg,  hsla(${hue}, 60%, 25%, 0.25),  hsla(${(hue + 90) % 360}, 60%, 20%, 0.2) )`,
					animation: `rainbow-shift 8s ease-in-out infinite`
				}
			},
			selectTopic(item) {
				this.selectedTopic = { ...item }
				this.getVocab()
			},
			getVocab() {
				if (!this.selectedTopic.ChuDeID) return
				ajaxCALL(vueData.v_Set.apiDomain + '/iotdev/auth/TiengAnh_Select', {
					ChuDeID: this.selectedTopic.ChuDeID,
					SearchKeyword: this.searchVocab
				}, res => { this.vocabList = res.data || [] })
			},
			openAddTopic() {
				this.formTopic = { ChuDeID: 0, TenChuDe: '', MoTaChuDe: '' }
				this.dialogTopic = true
			},
			editTopic(item) {
				this.formTopic = { ...item }
				this.dialogTopic = true
			},
			saveTopic() {
				if (!this.formTopic.TenChuDe.trim()) return alert('Nhập tên chủ đề!')
	
				const url = this.formTopic.ChuDeID
					? '/iotdev/auth/ChuDeTiengAnh_Update' : '/iotdev/auth/ChuDeTiengAnh_Insert'
	
				ajaxCALL(vueData.v_Set.apiDomain + url, this.formTopic, () => {
					this.dialogTopic = false
					this.getTopics() // Tải lại danh sách + số từ
					if (this.selectedTopic.ChuDeID === this.formTopic.ChuDeID) {
						this.selectedTopic = { ...this.formTopic }
					}
				})
			},
			onGoBack(topic) {
				const url = `https://iotdev.zentea.vn/clone-vue?chudeid=` + topic.ChuDeID;
				window.open(url, '_blank');
			},
			goToTest(topic) {
				const url = `https://iotdev.zentea.vn/test-tu-vung?testid=${topic.ChuDeID}`;
				window.open(url, '_blank'); // hoặc _self nếu muốn mở cùng tab
			},
			goToSearch(topic) {
				const url = `https://iotdev.zentea.vn/tu-dien-anh-viet`;
				window.open(url, '_blank'); // hoặc _self nếu muốn mở cùng tab
			},
			goToMotivation() {
				this.isShowMotivation = true
			},
			goToMultiTopicEnglish(topic) {
				const url = `https://iotdev.zentea.vn/tuvungthamkhao`;
				window.open(url, '_blank');
			},
			deleteTopic(record) {
				confirm({
					title: `Bạn có chắc muốn xóa chủ đề này: <b><i>${record.TenChuDe}</i></b>?`,
					action: () => { // ARROW → this = Vue instance
						ajaxCALL(vueData.v_Set.apiDomain + '/iotdev/auth/ChuDeTiengAnh_Delete', {
							ChuDeID: record.ChuDeID
						}, () => {
							this.getTopics()
							if (this.selectedTopic.ChuDeID === record.ChuDeID) {
								this.selectedTopic = {}
								this.vocabList = []
							}
						})
					}
				})
			},
			openAddVocab() {
				this.formVocab = {
					TiengAnhID: 0, TuVung: '', NghiaDenTA: '', NghiaDenTV: '', NghiaBong: '', NghiaBongTA: '', ViDuNghiaBong: '',
					ViDuNghiaDen: '', TuTraiNghia: '', ViDuTuTraiNghia: '', TuDongNghia: '', ViDuTuDongNghia: '', ThanhNguTA: '', ThanhNguTV: '', ViDuThanhNgu: ''
				}
				this.dialogVocab = true
			},
			editVocab(item) {
				this.formVocab = { ...item }
				this.dialogVocab = true
			},
			resetSelection() {
				this.selectedTopic = {}
				this.isSelected = false
				this.isViewingData = false
			},
			saveVocab() {
				if (!this.formVocab.TuVung.trim()) return alert('Nhập từ vựng!')
				if (!this.selectedTopic.ChuDeID) return alert('Chọn chủ đề!')
	
				const data = {
					TiengAnhID: this.formVocab.TiengAnhID,
					TuVung: this.formVocab.TuVung,
					NghiaDenTA: this.formVocab.NghiaDenTA || null,
					NghiaDenTV: this.formVocab.NghiaDenTV || null,
					NghiaBong: this.formVocab.NghiaBong || null,
					NghiaBongTA: this.formVocab.NghiaBongTA || null,
					ViDuNghiaBong: this.formVocab.ViDuNghiaBong || null,
					ViDuNghiaDen: this.formVocab.ViDuNghiaDen || null,
					TuTraiNghia: this.formVocab.TuTraiNghia || null,
					ViDuTuTraiNghia: this.formVocab.ViDuTuTraiNghia || null,
					TuDongNghia: this.formVocab.TuDongNghia || null,
					ViDuTuDongNghia: this.formVocab.ViDuTuDongNghia || null,
					ThanhNguTA: this.formVocab.ThanhNguTA || null,
					ThanhNguTV: this.formVocab.ThanhNguTV || null,
					ViDuThanhNgu: this.formVocab.ViDuThanhNgu || null,
					ChuDeID: Number(this.selectedTopic.ChuDeID) // BẮT BUỘC
				}
	
				const url = this.formVocab.TiengAnhID ? '/iotdev/auth/TiengAnh_Update' : '/iotdev/auth/TiengAnh_Insert'
	
				ajaxCALL(vueData.v_Set.apiDomain + url, data, () => {
					this.dialogVocab = false
					this.getVocab()
					this.getTopics()
				})
			},
			deleteVocab(item) {
				const $this = this
				confirm({
					title: 'Bạn có chắc muốn xóa từ vựng này ' + (item.TuVung.length > 0 ? "<b> <i>" + item.NghiaDenTV + "</i> </b>" :
						"<b> <i>" + item.NghiaBong + "</i> </b>"),
					action: function () {
						ajaxCALL(vueData.v_Set.apiDomain + '/iotdev/auth/TiengAnh_Delete', {
							TiengAnhID: item.TiengAnhID
						}, (res) => {
							console.log(res)
							// $this.getData()
							$this.getVocab() // Cập nhật bảng
							$this.getTopics()
						})
					},
				})
			},
			speakText(text) {
				const vietnameseRegex =
					/[àáạảãâầấậẩẫăằắặẳẵèéẹẻẽêềếệểễìíịỉĩòóọỏõôồốộổỗơờớợởỡùúụủũưừứựửữỳýỵỷỹđÀÁẠẢÃÂẦẤẬẨẪĂẰẮẶẲẴÈÉẸẺẼÊỀẾỆỂỄÌÍỊỈĨÒÓỌỎÕÔỒỐỘỔỖƠỜỚỢỞỠÙÚỤỦŨƯỪỨỰỬỮỲÝỴỶỸĐ]/;
				if (!("speechSynthesis" in window)) return;
				const words = text.split(/\s+/);
				const englishWords = words.filter(w => !vietnameseRegex.test(w));
				const filteredText = englishWords.join(" ");
				if (!filteredText.trim()) {
					console.log("Không có tiếng Anh để đọc");
					return;
				}
				const utterance = new SpeechSynthesisUtterance(filteredText);
				utterance.lang = "en-US";
				utterance.rate = 0.6;
				utterance.pitch = 1;
				window.speechSynthesis.cancel();
				window.speechSynthesis.speak(utterance);
			}
		}
	}
</script>
